<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Log Directory -->
    <property name="LOG_PATH" value="logs"/>

    <!-- Console Pattern -->
    <property name="CONSOLE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>

    <!-- File Pattern -->
    <property name="FILE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>

    <!-- ================= Console Appender ================= -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ================= Application Log File ================= -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/application.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/application.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ================= Error Log File ================= -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/error.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/error.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ============================================= -->
    <!-- ====== APPLICATION LOGGERS ====== -->
    <!-- ============================================= -->

    <!--
        IMPORTANT: Your application logs should go to FILE with DEBUG level
        But for CONSOLE, we only show ERROR level (or suppress completely)
    -->

    <!-- Controller - DEBUG for FILE, ERROR for CONSOLE -->
    <logger name="com.cloudFileStorageSystem.controller" level="DEBUG" additivity="false">
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR_FILE"/>
        <!--
            Don't add CONSOLE appender here if you don't want controller logs in console
            But if you add it, set the level to ERROR
        -->
    </logger>

    <!-- Service - DEBUG for FILE, ERROR for CONSOLE -->
    <logger name="com.cloudFileStorageSystem.service" level="DEBUG" additivity="false">
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </logger>

    <!-- Security - DEBUG for FILE, ERROR for CONSOLE -->
    <logger name="com.cloudFileStorageSystem.security" level="DEBUG" additivity="false">
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </logger>

    <!-- Repository - DEBUG for FILE, ERROR for CONSOLE -->
    <logger name="com.cloudFileStorageSystem.repository" level="DEBUG" additivity="false">
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </logger>

    <!-- ============================================= -->
    <!-- ====== ROOT LOGGER - This is the fallback ====== -->
    <!-- ============================================= -->

    <root level="INFO">
        <!--
            CONSOLE gets only ERROR and WARN from root
            But your API logs won't appear here because they're captured by the specific loggers above
        -->
        <appender-ref ref="CONSOLE"/>

        <!-- FILE gets everything (INFO and above) -->
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </root>

</configuration>